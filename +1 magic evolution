-- Configuration Coordinates
local autoWinCoords = { x = 3568.0078125, y = 1.9449999332427979, z = 8.189765930175781 }
local upgradeCoords = CFrame.new(-77.6232147, 1.79500353, 44.2061462, 1, 0, 0, 0, 1, 0, 0, 0, 1)

-- Automation Switches
local autoWinActive = false
local autoRebirthActive = false
