-- Loop A: Teleport & Upgrade Engine
RunService.Heartbeat:Connect(function()
    local character = localPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end

    if ultimateFarmActive and isUpgrading then
        character.HumanoidRootPart.CFrame = upgradeCoords
        task.wait(3.0)
        isUpgrading = false
        if floatHeightValue > 0 then teleportToHeight(floatHeightValue) end
    elseif (ultimateFarmActive or autoWinActive) then
        character.HumanoidRootPart.CFrame = CFrame.new(autoWinCoords.x, autoWinCoords.y, autoWinCoords.z)
    end
end)

-- Loop B: Rebirth Engine
