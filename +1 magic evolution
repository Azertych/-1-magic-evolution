-- Create the Invisible 2-Stud Thick Float Platform
local floatPlatform = Instance.new("Part")
floatPlatform.Size = Vector3.new(15, 2, 15)
floatPlatform.Anchored = true
floatPlatform.CanCollide = false
floatPlatform.Transparency = 1 -- Made completely invisible
floatPlatform.Material = Enum.Material.SmoothPlastic
floatPlatform.CastShadow = false
floatPlatform.Name = "InvisibleFloatPlatform"
floatPlatform.Parent = workspace

