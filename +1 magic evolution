-- Loop A: Continuous Smooth Teleportation Engine (No Blocking Waits)
RunService.Heartbeat:Connect(function()
    local character = localPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if ultimateFarmActive and isUpgrading then
        if os.clock() < upgradeEndTime then
            -- Keep locked on upgrade platform continuously for the 3 seconds
            hrp.CFrame = upgradeCoords
        else
            -- 3 seconds have passed, return to farming wins safely
            isUpgrading = false
            if floatHeightValue > 0 then teleportToHeight(floatHeightValue) end
        end
    elseif (ultimateFarmActive or autoWinActive) then
        hrp.CFrame = CFrame.new(autoWinCoords.x, autoWinCoords.y, autoWinCoords.z)
    end
end)

-- Loop B: Rebirth Engine
task.spawn(function()
    while true do
        if (autoRebirthActive or ultimateFarmActive) and RebirthRemote then
            RebirthRemote:FireServer()
        end
        task.wait(2.0) 
    end
end)

-- Loop C: Max-Speed Background Auto-Clicker
RunService.Heartbeat:Connect(function()
    if autoClickerActive and GainMagicPower then
        GainMagicPower:FireServer()
    end
end)

-- Loop D: Fixed Smooth Frame-Rate WalkSpeed Enforcement
RunService.Stepped:Connect(function()
    pcall(function()
        local character = localPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.WalkSpeed ~= walkSpeedValue then
            humanoid.WalkSpeed = walkSpeedValue
        end
    end)
end)

-- Loop E: Dynamic Real-time Platform Tracker
RunService.Heartbeat:Connect(function()
    local character = localPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        floatPlatform.CanCollide = false
        floatPlatform.CFrame = CFrame.new(0, -1000, 0)
        return 
    end
    local hrp = character.HumanoidRootPart

    if floatHeightValue > 0 then
        floatPlatform.CanCollide = true
        local staticY = lastGroundY + floatHeightValue - 1
        floatPlatform.CFrame = CFrame.new(hrp.Position.X, staticY, hrp.Position.Z)
    else
        floatPlatform.CanCollide = false
        floatPlatform.CFrame = CFrame.new(0, -1000, 0)
    end
end)

-- Smart Level Listener: Only triggers upgrade if level INCREASES
localPlayer:GetAttributeChangedSignal("Level"):Connect(function()
    local currentLevel = localPlayer:GetAttribute("Level") or 0
    
    if ultimateFarmActive and currentLevel > lastLevel and not isUpgrading then
        isUpgrading = true
        upgradeEndTime = os.clock() + 3.0 -- Set exact expiration timestamp
    end
    
    lastLevel = currentLevel -- Always update baseline to track future changes accurately
end)
